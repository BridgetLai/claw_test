{
  "manifest_version": 3,
  "name": "Recall Timer - 遗忘曲线复习提醒",
  "version": "1.0",
  "description": "根据艾宾浩斯遗忘曲线一键设置复习提醒闹钟",
  "permissions": ["notifications", "storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
